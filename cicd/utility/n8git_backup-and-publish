fMain(){

	## Settings
	local baseCmdArgs="a -r0 -ep1 -rr -m3"

	## Generic variables
	local -i wasShown_Copyright=0; local -i wasShown_About=0; wasShown_Syntax=0

	## Arguments: -q/--quiet (no prompt + quiet), --no-prompt (skip just the
	## confirm y/n but keep the review display; used when a caller like cicd has
	## already gated), -m/--message/--msg (commit message; -m MSG or -m=MSG),
	## -h/--help, -v/--version.
	local commitMessage=""
	while (($#)); do case "${1}" in
		-q|--quiet)                doQuietly=1                          ; shift ;;
		--no-prompt|--yes|-y)      doPromptToContinue=0                 ; shift ;;
		--message=*|--msg=*|-m=*)  commitMessage="${1#*=}"              ; shift ;;
		-m|--message|--msg)        commitMessage="${2-}"; shift; (($#)) && shift ;;
		-h|--help)                 fCopyright; fAbout; fSyntax          ; return 0 ;;
		-v|--ver|--version)        fCopyright                          ; return 0 ;;
		*) fThrowError "Unexpected option: '${1}' (try --help)." ;;
	esac; done

	## Auto-generate a commit message when quiet and none was given, so an
	## unattended publish never blocks on the commit-message editor.
	if [[ -z "${commitMessage}" ]] && ((doQuietly)); then commitMessage="Updated"; fi

	## Validate dependencies
	fMustBeInPath rar
	fMustBeInPath git

	## Settings; relative paths
	local -r dirPath_GitProj="."
	local -r dirName_GitProj="$(basename "$(readlink -f "${dirPath_GitProj}")")"
	local -r dirPath_Top=".."
	local -r dirName_Top="$(basename "$(readlink -f "${dirPath_Top}")")"
	local -r dirPath_Rar="${dirPath_Top}/versions"
	local -r filePath_Rar="${dirPath_Rar}/${dirName_Top}_${serialDT}.rar"
	baseCmdArgs="${baseCmdArgs} -x'*/${dirName_GitProj}/.git/*' -x'*/versions/*' -x'*/github/target/*' -x'*/private/backgrounds/*'"
	readonly baseCmdArgs
	local -r cmd_Rar="rar ${baseCmdArgs}  '${filePath_Rar}'  '../.'"

	## Validate
	[[ -f "${dirPath_GitProj}/.git/HEAD" ]]  ||  { fSyntax; fThrowError "Not in git project base directory."; }

	## Prompt to continue
	if ((! doQuietly)); then
		fCopyright
		fAbout
		if ((! skipBackup)); then
			fEcho_Clean "Archive source ...............: ${dirPath_GitProj}"
			fEcho_Clean "Archive target ...............: ${filePath_Rar}"
			fEcho_Clean
			fEcho_Clean "Rar command:"
			fEcho_Clean "${cmd_Rar}"
			fEcho_Clean
		fi
		fEcho_Clean "Remote info (git remote -v); make sure it's 'git@' and not 'https://':"
		git remote -v
		fEcho_Clean
		fEcho_Clean "Current branch (git branch --show-current):"
		git branch --show-current
		fEcho_Clean
		fEcho_Clean "git user info:"
		git config user.name
		git config user.email
		fEcho_Clean
		fEcho_Clean "SSH key being used"
		ssh -Tv git@github.com 2>&1 | grep -iE "offering|successfully authenticated" | sed 's/debug1: //' || true
		fIntroPromptToContinue  ""
		fEcho_Clean
	fi

	## Make backup dir
	if ((! skipBackup)); then
		[[ -d "${dirPath_Rar}" ]]  ||  mkdir -p "${dirPath_Rar}"

		fEcho "Creating version backup '${filePath_Rar}' ..."
		eval "${cmd_Rar}"

		## Prune old backups (GFS): keep ~30 - first + newest-per-
		## hour/day/week/month/year + the last 10. Also conforms pre-existing
		## backup names. Tunable via GFS_KEEP_* env (see include/gfs-rotate.bash).
		fEcho; fEcho "Rotating version backups (GFS retention) ..."
		## Non-fatal: pruning is housekeeping and must never abort a good publish.
		gfs_rotate "${dirPath_Rar}" "${dirName_Top}" rar || fEcho "WARNING: backup rotation failed (non-fatal); continuing."
	fi

	## Variables for git actions
	local -i didStash=0
	local -i preCount
	local -i postCount

	## Stash
	if ! git diff --quiet || ! git diff --cached --quiet; then
		fEcho; fEcho "git stash push --include-untracked..."
		preCount=$(git stash list | wc -l)
		git stash push --include-untracked -m "auto-stash"
		postCount=$(git stash list | wc -l)
		didStash=$((postCount > preCount ? 1 : 0))
	fi

	## Sync with this branch's upstream if it has one. A brand-new local branch
	## has nothing to pull; the push below sets its upstream on first publish.
	if git rev-parse --abbrev-ref @{u} >/dev/null 2>&1; then
		fEcho; fEcho "git pull --ff-only ..."
		## Fast-forward only: advance cleanly when the remote is ahead, but stop
		## if local and remote diverged so a real merge stays a deliberate human
		## step - never an auto-merge commit from an unattended publish.
		git pull --ff-only
	fi

	## Stash pop
	if ((didStash)); then
		fEcho; fEcho "git stash pop ..."
		git stash pop
	fi

	# Stage everything
	fEcho; fEcho "git add --all ..."
	git add --all

	if ! git diff --cached --quiet; then
		fEcho; fEcho "git commit ..."
		## -m keeps it hands-off; no message means an interactive editor.
		if [[ -n "${commitMessage}" ]]; then git commit -m "${commitMessage}"; else git commit; fi
	fi

	# Push only if we're ahead of the remote
	if ! git rev-parse --abbrev-ref @{u} >/dev/null 2>&1; then
		fEcho; fEcho "git push -u origin HEAD ..."
		git push -u origin HEAD
	elif [[ -n "$(git log @{u}.. 2>/dev/null)" ]]; then
		fEcho; fEcho "git push origin ..."
		git push origin
	fi

	## Done
	if ((! doQuietly)); then fEcho_Force; fEcho "${meName}: Done."; fi
:;}

