fCopyright(){ { ((doQuietly)) || ((wasShown_Copyright)); } && return; wasShown_Copyright=1;
	fEcho_Clean ""
#	fEcho_Clean "${meName} v${thisVersion} build ${thisBuild},"  ## Don't show version, it may confuse author with version of product being published.
	fEcho_Clean "${meName}, Copyright © ${thisCopyrightYear} ${thisAuthor}."
	fEcho_Clean "Licensed under The MIT License (MIT). Full text at:"
	fEcho_Clean "  https://mit-license.org/"
	fEcho_Clean "No Warranty."
	fEcho_Clean "" ;:;}

fAbout(){ { ((doQuietly)) || ((wasShown_About)); } && return; wasShown_About=1;
	fEcho_Clean ""
	#           X-------------------------------------------------------------------------------X
	fEcho_Clean "Backs up a github directory to a versioned archive, and publishes changes, ie:"
	fEcho_Clean "  • rar {flags} ../versions/{version}.rar  ../*"
	fEcho_Clean "  • git stash push --include-untracked &&  git pull --ff-only  &&  git stash pop"
	fEcho_Clean "  • git add --all  &&  git commit"
	fEcho_Clean "  • git push origin"
	#           X-------------------------------------------------------------------------------X
	fEcho_Clean "" ;:;}

fSyntax(){  { ((doQuietly)) || ((wasShown_Syntax)); } && return; wasShown_Syntax=1;
	fEcho_Clean ""
	#           X-------------------------------------------------------------------------------X
	fEcho_Clean "Arguments:"
	fEcho_Clean "  --quiet, -q [optional]: Be less verbose, and don't prompt user to continue."
	fEcho_Clean "  --no-prompt, --yes, -y [optional]: Skip the confirm prompt, keep the review."
	fEcho_Clean "  --message, --msg, -m [optional]: Commit message (-m MSG or -m=MSG)."
	fEcho_Clean "                                  Auto-generated when --quiet and no message."
	fEcho_Clean "  --help, --version [or -h, -v]"
	fEcho_Clean ""
	fEcho_Clean "Expected folder structure - something like:"
	fEcho_Clean "    project-name              [REQUIRED, any name, parent folder]"
	fEcho_Clean "    project-name/github       [REQUIRED, any name, →you should be here←]"
	fEcho_Clean "    project-name/github/.git  [REQUIRED, exact name, created by git]"
	fEcho_Clean "    project-name/priv         [0 to ∞ dirs, included in this backup]"
	fEcho_Clean "    project-name/versions     [REQUIRED, exact name, will be created by this]"

	#           X-------------------------------------------------------------------------------X
	fEcho_Clean "" ;:;}


